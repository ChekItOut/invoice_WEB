# Notion API 설정
# 1. https://www.notion.so/my-integrations 에서 새 Integration 생성
# 2. Internal Integration Token을 복사하여 아래에 붙여넣기
NOTION_API_KEY=ntn_your_integration_token_here

# 3. 노션 데이터베이스 페이지 URL에서 ID 추출
# URL 예시: https://www.notion.so/your-workspace/abc123def456?v=...
# ⚠️ 주의: @notionhq/client v5.9.0 이상에서는 database ID가 아닌 data source ID를 입력해야 합니다
# data source ID는 Integration 설정에서 확인하거나 dataSources.list() API로 조회할 수 있습니다
# 형식: 314ba96ef42680ad9c14000b023d595c (하이픈 없는 32자리)
NOTION_DATABASE_ID=your_database_id_here

# 공유 URL 생성용 (로컬: http://localhost:3000, 프로덕션: https://your-domain.com)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 관리자 인증 (Admin Authentication)
# 관리자 로그인에 사용할 비밀번호 (안전한 비밀번호 사용 권장)
ADMIN_PASSWORD=your_admin_password

# JWT 세션 암호화 키 (최소 32자 이상의 무작위 문자열)
# 예: openssl rand -base64 32 명령어로 생성 가능
JWT_SECRET=your_32_character_or_longer_secret_key
